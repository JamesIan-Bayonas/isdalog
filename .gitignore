# Laravel Standard Ignore
/vendor/
node_modules/
npm-debug.log
yarn-error.log
/public/hot
/public/storage
/storage/*.key
/storage/debugbar/
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/logs/*
!/storage/logs/.gitignore
/storage/app/private/*
!/storage/app/private/.gitignore
/storage/app/public/*
!/storage/app/public/.gitignore

# Environment Variables
.env
.env.backup
.env.production
.env.testing
.env.local

# Caching & IDEs
.phpunit.result.cache
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
.DS_Store
.idea
.vscode
*.sublime-workspace
*.sublime-project
.phpactor.json
/.fleet
/.nova
/.phpunit.cache